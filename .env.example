# Copy this file to `.env` and fill in values.
# NEVER commit real keys to git.

# Used when OCR method is set to "Gemini (API)" (or Auto fallback).
GOOGLE_API_KEY=

# Optional: override the Gemini model used for OCR.
# GEMINI_OCR_MODEL=gemini-1.5-flash

# Optional: path to the local Tesseract OCR binary (recommended for Week 2 OCR on Windows)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
